# -- runtime envs --

NEXT_PUBLIC_LIVE_URL=http://localhost:4000
API_URL=http://localhost:4001

# DISABLE_IFRAME=0

# TRACKING_ID=
# TRACKING_URL=

# -- news feed & push notifications --

# Twitter / X API — get from developer.twitter.com
TWITTER_BEARER_TOKEN=

# Your @f1_naija numeric user ID — get from commentpicker.com/twitter-id.php
TWITTER_USER_ID=

# VAPID keys — generate your own with: npx web-push generate-vapid-keys
# Store the real values in Railway / Vercel env vars, NEVER commit real keys here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your_email_here

# Secret to protect the /api/notify endpoint — set to any strong random string
NOTIFY_SECRET=

# OneSignal App ID — get from onesignal.com dashboard
NEXT_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id_here

# Push service URL (Railway) — already deployed
NEXT_PUBLIC_PUSH_SERVICE_URL=https://your-push-service.up.railway.app

# -- build envs --
# SKIP_ENV_VALIDATION=1   # skips env validation, use for docker
# NEXT_STANDALONE=1       # enables nextjs standalone build, use for docker
# NEXT_NO_COMPRESS=1      # disables nextjs compression, use when using proxy compression
